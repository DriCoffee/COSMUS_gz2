    <include>
      <name>plane04</name>
      <uri>file:///home/drik/Projetos/_COSMUS/COSMUS_gz2/models/plane/plane04.sdf</uri>
      <pose>0 -2 0.13 0 0 0</pose>
    </include>

  -->

  </world>
</sdf>
